# ============================================
# Zyllen Gestão — Environment Variables
# ============================================

# Database
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET="OBRIGATORIO: gere com → node -e \"console.log(require('crypto').randomBytes(64).toString('hex'))\" — mínimo 64 chars"
JWT_EXPIRES_IN="1d"
JWT_REFRESH_EXPIRES_IN="7d"

# CPF Encryption (AES-256-CBC) — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CPF_ENCRYPTION_KEY="OBRIGATORIO: 64 chars hex (32 bytes)"

# API
API_PORT=3001
NODE_ENV=development

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001
